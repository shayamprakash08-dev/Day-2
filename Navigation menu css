body {
    margin: 0;
    font-family: Arial, sans-serif;
}

.navbar {
    background-color: #2c3e50;
    padding: 15px 0;
    text-align: center;
}

.navbar a {
    color: #ffffff;
    text-decoration: none;
    font-size: 18px;
    padding: 10px 20px;
    margin: 0 10px;
    display: inline-block;
    transition: all 0.3s ease;
}

.navbar a:hover {
    background-color: #34495e;
    color: #f1c40f;
    border-radius: 5px;
}
